PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:5173

# Postgres connection string — from Neon, Supabase, Railway, or your own instance.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# Any long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Only this email can sign in to /admin — use the email of the Firebase
# user you create for yourself.
ADMIN_EMAIL=you@example.com

# Firebase Admin SDK credentials — Firebase Console > Project settings >
# Service accounts > Generate new private key. Copy the three fields below
# from the downloaded JSON (keep the \n characters in the private key as-is,
# wrapped in quotes).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

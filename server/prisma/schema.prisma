generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A single portfolio project shown in the Projects section and on its
/// own details page.
model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  techStack   String[]
  image       String
  liveLink    String?
  githubLink  String?
  challenges  String?
  futurePlans String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

/// A message submitted through the public contact form.
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
